# Slack Tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Git repo path
REPO_PATH=/path/to/your/repo

# Test command (optional, default: dazel test ...)
# TEST_COMMAND=python3 -m pytest tests/ -v 2>&1

# Test timeout in seconds (optional, default: 3600)
# TEST_TIMEOUT=3600

# Shell init command (optional, default: source ~/.bashrc)
# SHELL_INIT=source ~/.bashrc

# Cursor Agent CLI path (optional)
# AGENT_BIN=/home/alvichen/.local/bin/agent
# AGENT_TIMEOUT=300
# AGENT_MODEL=gpt-5.3-codex-fast

# Log retention in hours (optional, default: 36)
# LOG_RETAIN_HOURS=36

# Admin Slack user IDs, comma-separated (notified on hold)
# ADMIN_USER_IDS=U090D47C140,U0ANOTHER
